                    end)
                    ob.MouseButton1Down:Connect(function(x, y) ripple(ob, x, y, theme.AccentHi) end)
                    ob.MouseButton1Click:Connect(function()
                        if multi then
                            selected[opt] = not selected[opt]
                            val.Text = displayText()
                            ob.Text = "   " .. opt .. (selected[opt] and "   \u{2713}" or "")
                            ob.BackgroundColor3 = theme.Accent
                            ob.BackgroundTransparency = selected[opt] and 0 or 1
                            local list = {}
                            for _, o in ipairs(options) do if selected[o] then table.insert(list, o) end end
                            if opts.Flag then Library.Flags[opts.Flag] = list end
                            if opts.Callback then task.spawn(opts.Callback, list) end
                        else
                            selected = opt
                            val.Text = opt
                            refresh()
                            tween(row, 0.22, {Size = UDim2.new(1, -8, 0, COLLAPSED_H)})
                            tween(listScroll, 0.22, {Size = UDim2.new(1, -20, 0, 0)})
