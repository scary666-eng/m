    -- ── Favorite-search persistence ────────────────────────────────────────
    -- Favorites are keyed by a stable "<tab>|<kind>|<name>" string so they
    -- survive across executions (entry tables themselves are recreated each
    -- time the UI is built). Saves are debounced; loads happen here so that
    -- registerSearch (called later per-tab) can mark matching entries.
    local function favoritesPath()
        local folder = Window.ConfigFolder or sanitizeConfigName(name)
        return string.format("%s/favorites.json", folder)
    end
    local function entryKey(entry)
        if type(entry) ~= "table" then return nil end
        local tab = (entry.Tab and entry.Tab.Name) or "?"
        return string.format("%s|%s|%s", tab, entry.Kind or "", entry.Name or "")
    end
    Window._FavoriteEntryKey = entryKey
    Window.SavedFavoriteKeys = {}
    if type(readfile) == "function" and type(isfile) == "function" then
        local okRead, raw = pcall(function()
            local p = favoritesPath()
            if isfile(p) then return readfile(p) end
        end)
        if okRead and type(raw) == "string" and raw ~= "" then
            local okDec, decoded = pcall(HttpService.JSONDecode, HttpService, raw)
            if okDec and type(decoded) == "table" then
                local list = decoded.keys
                if type(list) == "table" then
                    for _, k in ipairs(list) do
                        if type(k) == "string" then
                            Window.SavedFavoriteKeys[k] = true
                        end
                    end
                end
            end
        end
    end
    local favSaveToken = 0
    local function writeFavoritesFile()
        if type(writefile) ~= "function" then return end
        local folder = Window.ConfigFolder or sanitizeConfigName(name)
        if type(isfolder) == "function" and not isfolder(folder) then
            if type(makefolder) == "function" then pcall(makefolder, folder) end
        end
        -- Build the saved-keys set from the live Favorites map, then merge
        -- in any previously-saved keys whose entries haven't been registered
        -- yet this session (e.g., a tab that wasn't opened). This prevents
        -- favorites from silently disappearing the first time you toggle one
        -- before all tabs have been built.
        local seen = {}
        local keys = {}
        for entry, flag in pairs(Window.Favorites) do
            if flag then
                local k = entryKey(entry)
                if k and not seen[k] then
                    seen[k] = true
                    table.insert(keys, k)
                end
            end
        end
        local liveEntries = {}
        for _, e in ipairs(Window.Searchables) do
            local k = entryKey(e)
            if k then liveEntries[k] = true end
        end
        for k, v in pairs(Window.SavedFavoriteKeys) do
            if v and not seen[k] and not liveEntries[k] then
                seen[k] = true
                table.insert(keys, k)
            end
        end
        local payload = { __vantaFavorites = 1, keys = keys }
        local okEnc, encoded = pcall(HttpService.JSONEncode, HttpService, payload)
        if not okEnc then return end
        pcall(writefile, favoritesPath(), encoded)
    end
