--- Faux liquid-glass surface: bright rim + diagonal cool gradient (specular read top-left).
local function applyLiquidGlass(inst, theme, cornerRadius, rimTransparency)
    rimTransparency = rimTransparency ~= nil and rimTransparency or 0.42
    local gl = theme.GlassLite or THEME.GlassLite
    local gm = theme.GlassMid or THEME.GlassMid
    local gd = theme.GlassDeep or THEME.GlassDeep
    local rim = theme.GlassRim or THEME.GlassRim
    local baseT = theme.GlassBaseTransparency or THEME.GlassBaseTransparency
    inst.BackgroundColor3 = Color3.new(1, 1, 1)
    inst.BackgroundTransparency = baseT
    local grad = inst:FindFirstChildOfClass("UIGradient")
    if not grad then
        grad = new("UIGradient", { Parent = inst })
    end
    grad.Rotation = GLASS_GRAD_ROT
    setGlassGradient(grad, gl, gm, gd)
    local uc = inst:FindFirstChildOfClass("UICorner")
    if not uc then
        corner(inst, cornerRadius)
    else
        uc.CornerRadius = UDim.new(0, cornerRadius)
    end
    local s = inst:FindFirstChildOfClass("UIStroke")
    if not s then
        s = stroke(inst, rim, 1, rimTransparency)
    else
        s.Color = rim
        s.Thickness = 1
        s.Transparency = rimTransparency
    end
    s.LineJoinMode = Enum.LineJoinMode.Round
    return s, grad
end

local function hsvToRgb(h, s, v) return Color3.fromHSV(h, s, v) end

local function rgbToHsv(c)
    local r, g, b = c.R, c.G, c.B
    local max, min = math.max(r, g, b), math.min(r, g, b)
    local h, s, v = 0, 0, max
    local d = max - min
    s = max == 0 and 0 or d / max
    if max == min then
        h = 0
    else
        if     max == r then h = (g - b) / d + (g < b and 6 or 0)
        elseif max == g then h = (b - r) / d + 2
        else                 h = (r - g) / d + 4 end
        h = h / 6
    end
    return h, s, v
end

