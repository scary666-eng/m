                    task.delay(0.22, function() if not open then panel.Visible = false end end)
                end
            end)

            if opts.Flag then Library.Flags[opts.Flag] = color end

            addOrder(row)
            registerSearch(opts.Name, row, "colorpicker", opts.Flag, nil)
            local obj = {}
            function obj:Set(c)
                color = c
                h, s, v = rgbToHsv(c)
                updateColor(true)
            end
            function obj:Get() return color end
            registerFlagControl(opts.Flag, obj)
            return obj
        end

