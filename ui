                    tween(listScroll, 0.24, {Size = UDim2.new(1, -20, 0, 0)})
                    tween(caret, 0.24, {Rotation = 0})
                    task.delay(0.24, function() if not open then listScroll.Visible = false end end)
                end
            end)

            addOrder(row)
            registerSearch(opts.Name, row, "dropdown", opts.Flag, nil)

            local obj = {}
            function obj:Set(v)
                if multi then
                    selected = {}
                    if type(v) == "table" then for _, x in ipairs(v) do selected[x] = true end end
                else
                    if type(v) == "table" then v = v[1] end
                    selected = v
                end
                val.Text = displayText()
                refresh()
                if opts.Flag then
                    if multi then
                        local list = {}
                        for _, o in ipairs(options) do if selected[o] then table.insert(list, o) end end
                        Library.Flags[opts.Flag] = list
                    else
                        Library.Flags[opts.Flag] = selected
                    end
                end
            end
            function obj:Refresh(newOpts)
                options = newOpts or {}
                if multi then
                    local kept = {}
                    for _, o in ipairs(options) do if selected[o] then kept[o] = true end end
                    selected = kept
                else
                    local found = false
                    for _, o in ipairs(options) do if o == selected then found = true break end end
                    if not found then selected = options[1] end
                end
                val.Text = displayText()
                refresh()
            end
            function obj:Get()
                if multi then
                    local l = {}
                    for _, o in ipairs(options) do if selected[o] then table.insert(l, o) end end
                    return l
                else
                    return selected
                end
            end
            registerFlagControl(opts.Flag, obj)
            return obj
        end

