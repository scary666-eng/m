        local function fuzzyScore(name, q)
            if q == "" then return 1 end
            name = string.lower(name)
            local idx = string.find(name, q, 1, true)
            if idx then
                if idx == 1 then return 3.0 end
                return 2.0 - (idx / #name) * 0.5
            end
            local ni = 1
            for ci = 1, #q do
                local c = q:sub(ci, ci)
                local pos = string.find(name, c, ni, true)
                if not pos then return 0 end
                ni = pos + 1
            end
            return 1.0 - (#q / math.max(#name, 1)) * 0.3
        end

