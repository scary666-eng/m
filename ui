    local function readMobile()
        if cfg.Mobile then return true end
        if rawget(_G, "mobile_ui") then return true end
        if rawget(_G, "Vanta_Mobile") then return true end
        if type(shared) == "table" and rawget(shared, "mobile_ui") then
