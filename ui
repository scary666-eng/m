        tween(dashboardOverlay, 0.28, {
            Position = UDim2.fromOffset(0, WIN_H),
            Size     = UDim2.new(1, 0, 0, 0),
        }, Enum.EasingStyle.Quint, Enum.EasingDirection.In)
        task.delay(0.30, function()
            if dashboardOverlay and dashboardOverlay.Parent then
                dashboardOverlay.Visible  = false
                dashboardOverlay.Position = UDim2.fromOffset(0, BAR_H - 18)
                dashboardOverlay.Size     = UDim2.new(1, 0, 1, -BAR_H + 18)
