local function httpGetRobust(url)
    local ok, src = pcall(game.HttpGet, game, url)
    if ok and type(src) == "string" and #src > 80 then
        return src
    end
    if syn and type(syn.request) == "function" then
        local ok2, res = pcall(syn.request, { Url = url, Method = "GET" })
        if ok2 and res and type(res.Body) == "string" and #res.Body > 80 then
            return res.Body
        end
    end
    if type(request) == "function" then
        local ok2, res = pcall(request, { Url = url, Method = "GET" })
        if ok2 and res and type(res.Body) == "string" and #res.Body > 80 then
            return res.Body
        end
    end
    if type(http_request) == "function" then
        local ok2, res = pcall(http_request, { Url = url, Method = "GET" })
        if ok2 and res and type(res.Body) == "string" and #res.Body > 80 then
            return res.Body
        end
    end
    return nil
end

