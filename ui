        local function refresh()
            clearResults()
            local q = string.lower((input.Text or ""):gsub("^%s+", ""):gsub("%s+$", ""))
            local scored = {}
            for _, e in ipairs(Window.Searchables) do
                if e.Name and e.Name ~= "" then
                    local s = fuzzyScore(e.LowerName or "", q)
                    if s > 0 then table.insert(scored, { e = e, s = s }) end
                end
            end
            table.sort(scored, function(a, b)
                local fa = Window.Favorites[a.e] == true
                local fb = Window.Favorites[b.e] == true
                if fa ~= fb then return fa end
                if a.s == b.s then return (a.e.Name or "") < (b.e.Name or "") end
                return a.s > b.s
            end)
            local limit = math.min(#scored, 40)
            activeMatches = {}
            for i = 1, limit do
                activeMatches[i] = scored[i].e
                buildRow(scored[i].e, i)
            end
            emptyLbl.Visible = (limit == 0)
            activeIdx = math.min(activeIdx, math.max(1, limit))
            highlightActive()
            firstRender = false
