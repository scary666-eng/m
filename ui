-- Rayfield compact row: { assetId, {w,h}, {x,y} }
local function iconDataFromRayfieldRow(d)
    if type(d) ~= "table" then return nil end
    if type(d[1]) == "number" and type(d[2]) == "table" and type(d[3]) == "table" then
        return {
            Image = "rbxassetid://" .. tostring(d[1]),
            ImageRectSize = Vector2.new(d[2][1] or 48, d[2][2] or 48),
            ImageRectOffset = Vector2.new(d[3][1] or 0, d[3][2] or 0),
        }
    end
    return nil
end

local function findIconInRayfieldPack(pack, name, lower)
    if type(pack) ~= "table" then return nil end
    local order = { "48px", "32px", "24px", "16px" }
    for _, key in ipairs(order) do
        local bucket = pack[key]
        if type(bucket) == "table" then
            local row = bucket[name] or bucket[lower]
            if row then
                local parsed = iconDataFromRayfieldRow(row)
                if parsed then return parsed end
            end
            for k, v in pairs(bucket) do
                if string.lower(tostring(k)) == lower then
                    local p = iconDataFromRayfieldRow(v)
                    if p then return p end
                end
            end
        end
    end
    for k, bucket in pairs(pack) do
        if type(k) == "string" and k:find("px", 1, true) and type(bucket) == "table" then
            local row = bucket[name] or bucket[lower]
            if row then
                local parsed = iconDataFromRayfieldRow(row)
                if parsed then return parsed end
            end
        end
    end
    return nil
end

