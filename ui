    local function deriveAccentRamp(c)
        local h, sv, vv = rgbToHsv(c)
        return {
            Accent     = c,
            AccentHi   = hsvToRgb(h, math.max(0.30, sv * 0.85), math.min(1.00, vv * 1.12)),
            AccentMid  = hsvToRgb(h, sv,                       math.max(0.55, vv * 0.85)),
            AccentDeep = hsvToRgb(h, math.min(1.00, sv * 1.10), math.max(0.32, vv * 0.55)),
        }
    end

    -- Theme application via tree-walker: any Color3 prop or gradient stop on a
    -- descendant of the window that equals an OLD theme value gets remapped to
    -- the corresponding NEW value. Catches every control built off the theme
    -- without per-element registration.
    local function applyTheme(presetName, accentColor)
        local newTheme = {}
        for k, v in pairs(lastTheme) do newTheme[k] = v end
        local preset = presetName and THEME_PRESETS[presetName]
        if preset then for k, v in pairs(preset) do newTheme[k] = v end end
        if accentColor then
            for k, v in pairs(deriveAccentRamp(accentColor)) do newTheme[k] = v end
        end

        local remap = {}
        for k, oldV in pairs(lastTheme) do
            local newV = newTheme[k]
            if typeof(oldV) == "Color3" and typeof(newV) == "Color3"
               and (oldV.R ~= newV.R or oldV.G ~= newV.G or oldV.B ~= newV.B) then
                remap[colorKey(oldV)] = newV
            end
        end

        if next(remap) == nil then
            for k, v in pairs(newTheme) do theme[k] = v end
            for k, v in pairs(newTheme) do lastTheme[k] = v end
            setHeaderButtonContrast()
            return
        end

        local function tryRemap(inst, prop)
            local val = inst[prop]
            if typeof(val) ~= "Color3" then return end
            local n = remap[colorKey(val)]
            if n then inst[prop] = n end
        end

        local function tryRemapGradient(grad)
            local seq = grad.Color
            local kp = seq.Keypoints
            local newKps = {}
            local changed = false
            for _, p in ipairs(kp) do
                local n = remap[colorKey(p.Value)]
                if n then
                    changed = true
                    table.insert(newKps, ColorSequenceKeypoint.new(p.Time, n))
                else
                    table.insert(newKps, p)
                end
            end
            if changed then grad.Color = ColorSequence.new(newKps) end
        end

        -- Single descent list; per-property indexing only on classes that *have* the property
        -- (e.g. PlaceholderColor3 is TextBox-only; reading it on TextLabel throws).
        local descendants = canvas:GetDescendants()
        for i = 1, #descendants do
            local inst = descendants[i]
            local cn = inst.ClassName
            if cn == "Frame" or cn == "ScrollingFrame" or cn == "TextLabel"
               or cn == "TextButton" or cn == "TextBox" or cn == "ImageLabel"
               or cn == "ImageButton" then
                tryRemap(inst, "BackgroundColor3")
                if cn == "TextLabel" or cn == "TextButton" or cn == "TextBox" then
                    tryRemap(inst, "TextColor3")
                    if cn == "TextBox" then
                        tryRemap(inst, "PlaceholderColor3")
                    end
                end
                if cn == "ImageLabel" or cn == "ImageButton" then
                    tryRemap(inst, "ImageColor3")
                end
                if cn == "ScrollingFrame" then
                    tryRemap(inst, "ScrollBarImageColor3")
                end
            elseif cn == "UIStroke" then
                tryRemap(inst, "Color")
            elseif cn == "UIGradient" then
                tryRemapGradient(inst)
            end
        end

        for k, v in pairs(newTheme) do theme[k] = v end
        for k, v in pairs(newTheme) do lastTheme[k] = v end
        setHeaderButtonContrast()
    end

