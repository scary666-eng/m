-- normalize icon lookup to {Image, ImageRectOffset, ImageRectSize}
local function resolveIcon(name)
    if not name then return nil end
    if type(name) ~= "string" then name = tostring(name) end
    local lower = string.lower(name)

    local customId = CUSTOM_ICON_ASSETS[lower]
    if customId then
        return iconFromAssetId(customId)
    end

    if LucideIcons then
        -- Rayfield main/icons.lua uses buckets like ["48px"] = { sword = { id, {48,48}, {x,y} }, ... }
        local ray = findIconInRayfieldPack(LucideIcons, name, lower)
        if ray then return ray end

        local d
        if type(LucideIcons.GetAsset) == "function" then
            local ok, v = pcall(LucideIcons.GetAsset, name)
            if ok and v then d = v end
            if not d then
                ok, v = pcall(LucideIcons.GetAsset, lower)
                if ok then d = v end
            end
        end
        if not d and type(LucideIcons.Icons) == "table" then
            d = LucideIcons.Icons[name] or LucideIcons.Icons[lower]
        end
        if not d then d = LucideIcons[name] or LucideIcons[lower] end

        if type(d) ~= "table" then return nil end
        local fromRow = iconDataFromRayfieldRow(d)
        if fromRow then return fromRow end

        local img = d.Url or d.Image or (d.id and ("rbxassetid://" .. tostring(d.id)))
        if not img then return nil end
        return {
            Image = img,
            ImageRectOffset = d.ImageRectOffset or Vector2.new(0, 0),
            ImageRectSize   = d.ImageRectSize   or Vector2.new(0, 0),
        }
    end

    return nil
end

-- Emulates group fade without CanvasGroup (which composites the whole UI to a texture = blurry).
-- Updates run in a few discrete steps so we do not hitch every RenderStep like the old tween hook.
local function collectTransparencyBaseline(root)
    local out = {}
    local function push(inst, prop)
        local v = inst[prop]
        if typeof(v) == "number" then
            out[#out + 1] = { inst, prop, v }
        end
    end
    local function consider(inst)
        if inst:IsA("GuiObject") then
            push(inst, "BackgroundTransparency")
        end
        if inst:IsA("TextLabel") or inst:IsA("TextButton") or inst:IsA("TextBox") then
            push(inst, "TextTransparency")
        end
        if inst:IsA("ImageLabel") or inst:IsA("ImageButton") then
            push(inst, "ImageTransparency")
        end
        if inst:IsA("UIStroke") then
            push(inst, "Transparency")
        end
    end
    consider(root)
    for _, inst in ipairs(root:GetDescendants()) do
        consider(inst)
    end
    return out
end

local function applyEmulatedGroupTransparency(baseline, groupTransparency)
    for i = 1, #baseline do
        local row = baseline[i]
        local inst, prop, base = row[1], row[2], row[3]
        if inst.Parent then
            inst[prop] = 1 - (1 - base) * (1 - groupTransparency)
        end
    end
end

