    local function toggleCanvasVisibility()
        if not canvas or not canvas.Parent then return end
        -- High-FPS toggle with animation locking. No text scale changes.
        if Window.ToggleInFlight then return end
        Window.ToggleInFlight = true
        Window.ToggleAnimToken = (Window.ToggleAnimToken or 0) + 1
        local myTok = Window.ToggleAnimToken

        local function yOffset(pos, dy)
            return UDim2.new(pos.X.Scale, pos.X.Offset, pos.Y.Scale, pos.Y.Offset + dy)
        end

        local targetHide = not Window.HiddenByToggle
        if targetHide then
            Window.HiddenByToggle = true
            canvas.Visible = true
            local basePos = windowFrame.Position
            tween(windowFrame, 0.11, { Position = yOffset(basePos, -6) }, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
            task.delay(0.12, function()
                if myTok ~= Window.ToggleAnimToken then return end
                if Window.HiddenByToggle and canvas and canvas.Parent then
                    canvas.Visible = false
                    windowFrame.Position = basePos
                end
                if myTok == Window.ToggleAnimToken then
                    Window.ToggleInFlight = false
                end
            end)
        else
            Window.HiddenByToggle = false
            local basePos = windowFrame.Position
            canvas.Visible = true
            windowFrame.Position = yOffset(basePos, -6)
            tween(windowFrame, 0.12, { Position = basePos }, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
            task.delay(0.13, function()
                if myTok == Window.ToggleAnimToken then
                    Window.ToggleInFlight = false
                end
            end)
        end
    end

    function Window:Toggle()
