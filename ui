    local function applyFlagValue(flag, value)
        if not flag or flag == "" then return false end
        local cloned = cloneConfigValue(value)
        Library.Flags[flag] = cloned
        local ctl = Window.FlagControls[flag]
        if ctl and type(ctl.Set) == "function" then
            return pcall(function()
                ctl:Set(cloned)
            end)
        end
        Window.PendingConfigFlags[flag] = cloned
        return true
    end

    local function ensureConfigFolder(folder)
        if type(isfolder) == "function" and isfolder(folder) then
            return true
        end
        if type(makefolder) ~= "function" then
            return false
        end
        return pcall(makefolder, folder)
    end

    function Window:SetConfigFolder(folder)
        Window.ConfigFolder = sanitizeConfigName(folder or Window.ConfigFolder or name)
        return Window.ConfigFolder
    end

    function Window:SetConfigFile(fileName)
        Window.ConfigFile = sanitizeConfigName(fileName or Window.ConfigFile or "default")
        return Window.ConfigFile
    end

    function Window:GetConfigPath(fileName)
        local folder = Window.ConfigFolder or sanitizeConfigName(name)
        local file = sanitizeConfigName(fileName or Window.ConfigFile or "default")
        return string.format("%s/%s.json", folder, file)
    end

    function Window:SaveConfig(fileName)
        if type(writefile) ~= "function" then
            return false, "writefile unavailable"
        end
        local folder = Window.ConfigFolder or sanitizeConfigName(name)
        local path = Window:GetConfigPath(fileName)
        if not ensureConfigFolder(folder) then
            return false, "could not create config folder"
        end
        local flags = {}
        for flag, value in pairs(Library.Flags) do
            flags[flag] = encodeConfigValue(value)
        end
        local payload = {
            __vantaConfig = 1,
            window = name,
            flags = flags,
        }
        local ok, encoded = pcall(HttpService.JSONEncode, HttpService, payload)
        if not ok then
            return false, "json encode failed"
        end
        local wrote = pcall(writefile, path, encoded)
        if not wrote then
            return false, "write failed"
        end
        return true, path
    end

    function Window:LoadConfig(fileName)
        if type(readfile) ~= "function" or type(isfile) ~= "function" then
            return false, "readfile/isfile unavailable"
        end
        local path = Window:GetConfigPath(fileName)
        if not isfile(path) then
            return false, "config not found"
        end
        local okRead, raw = pcall(readfile, path)
        if not okRead or type(raw) ~= "string" then
            return false, "read failed"
        end
        local okDecode, decoded = pcall(HttpService.JSONDecode, HttpService, raw)
        if not okDecode or type(decoded) ~= "table" then
            return false, "json decode failed"
        end
        local sourceFlags = decoded.flags
        if type(sourceFlags) ~= "table" then
            sourceFlags = decoded
        end
        for flag, encValue in pairs(sourceFlags) do
            if type(flag) == "string" and string.sub(flag, 1, 2) ~= "__" then
                applyFlagValue(flag, decodeConfigValue(encValue))
            end
        end
        -- Ensure theme is applied immediately, even if the settings control
        -- does not invoke callbacks during `Set`.
        local loadedTheme = sourceFlags["Vanta_Theme"]
        if type(loadedTheme) == "string" and loadedTheme ~= "" then
            applyTheme(loadedTheme, nil)
        end
        return true, path
    end

