        dashboardVisible = false
        -- Collapse height while pinning the bottom edge to the card's bottom
        -- (Position.Y + Size.Y stays at WIN_H throughout). This keeps the
        -- overlay's rounded bottom corners aligned with the card's rounded
        -- bottom corners during the entire animation, instead of letting the
