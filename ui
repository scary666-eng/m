    function Window:SelectTab(tab)
        if not tab then return end
        if Window.ActiveTab == tab then return end

        local prev = Window.ActiveTab
        local doSwipe = prev ~= nil and prev ~= tab and prev.PageShell ~= nil and tab.PageShell ~= nil

        Window.TabDotPulseSeq = Window.TabDotPulseSeq + 1
        local pulseSeq = Window.TabDotPulseSeq

        for _, t in ipairs(Window.Tabs) do
            local active = (t == tab)
            if not doSwipe then
                if t.PageShell then
                    t.PageShell.Visible = active
                    t.PageShell.Position = UDim2.fromScale(0, 0)
                else
                    t.Page.Visible = active
                end
            elseif t ~= tab and t ~= prev then
                if t.PageShell then
                    t.PageShell.Visible = false
                    t.PageShell.Position = UDim2.fromScale(0, 0)
                else
                    t.Page.Visible = false
                end
            end

            if t.TabGrad and t.TabStroke then
                if active then
                    setGlassGradient(t.TabGrad, theme.GlassTabActiveLite, theme.GlassTabActiveMid, theme.GlassTabActiveDeep)
                    tween(t.Button, 0.22, { BackgroundTransparency = 0.26 })
                    tween(t.TabStroke, 0.22, { Transparency = 0.1, Color = theme.GlassRimHi })
                else
                    setGlassGradient(t.TabGrad, theme.GlassTabInactiveLite, theme.GlassTabInactiveMid, theme.GlassTabInactiveDeep)
                    tween(t.Button, 0.22, { BackgroundTransparency = 0.52 })
                    tween(t.TabStroke, 0.22, { Transparency = 0.42, Color = theme.GlassRim })
                end
            end
            tween(t.Label, 0.22, { TextColor3 = active and theme.AccentDeep or theme.SubText })
            if active then
                if t.Dot then
                    tween(t.Dot, 0.22, { BackgroundColor3 = theme.AccentHi })
                end
                if t.Icon then
                    t.Icon.Rotation = -10
                    tween(t.Icon, 0.36, { Rotation = 0, ImageColor3 = theme.AccentDeep }, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
                end
                task.spawn(function()
                    local mySeq = pulseSeq
                    while mySeq == Window.TabDotPulseSeq do
                        if not t.Dot then return end
                        tween(t.Dot, 0.85, { BackgroundColor3 = theme.AccentHi })
                        task.wait(0.85)
                        if mySeq ~= Window.TabDotPulseSeq then return end
                        tween(t.Dot, 0.85, { BackgroundColor3 = theme.AccentMid })
                        task.wait(0.85)
                        if mySeq ~= Window.TabDotPulseSeq then return end
                    end
                end)
            else
                if t.Dot then
                    tween(t.Dot, 0.22, { BackgroundColor3 = theme.Muted })
                end
                if t.Icon then
                    tween(t.Icon, 0.22, { ImageColor3 = theme.SubText })
                end
            end
        end

        Window.ActiveTab = tab
        applyActiveTabHeader(tab)

        if not doSwipe then
            return
        end

        cancelTabSwipeTweens()
        for _, t in ipairs(Window.Tabs) do
            if t.PageShell then
                t.PageShell.Position = UDim2.fromScale(0, 0)
            end
        end

        Window.TabSwipeSeq = Window.TabSwipeSeq + 1
        local swipeId = Window.TabSwipeSeq

        local idxOld = tabIndex(prev)
        local idxNew = tabIndex(tab)
        local dir = (idxNew >= idxOld) and 1 or -1

        local outS = prev.PageShell
        local inS = tab.PageShell

        outS.Visible = true
        inS.Visible = true
        outS.ZIndex = 14
        inS.ZIndex = 15
        outS.Position = UDim2.fromScale(0, 0)
        inS.Position = UDim2.fromScale(dir, 0)

        -- Do not UIScale-tween tab content: it scales all text and looks like fonts resizing.

        local swipeDur = 0.32
        local swipeStyle = Enum.EasingStyle.Quint
        local swipeDir = Enum.EasingDirection.Out

        local twOut = TweenService:Create(
            outS,
            TweenInfo.new(swipeDur, swipeStyle, swipeDir),
            { Position = UDim2.fromScale(-dir, 0) }
        )
        local twIn = TweenService:Create(
            inS,
            TweenInfo.new(swipeDur, swipeStyle, swipeDir),
            { Position = UDim2.fromScale(0, 0) }
        )

        table.insert(tabSwipeTweens, twOut)
        table.insert(tabSwipeTweens, twIn)

        twIn.Completed:Connect(function()
            if swipeId ~= Window.TabSwipeSeq then return end
            outS.Visible = false
            outS.Position = UDim2.fromScale(0, 0)
            inS.ZIndex = 13
            outS.ZIndex = 13
            local oldScale = inS:FindFirstChild("TabSwipeUIScale")
            if oldScale then
                oldScale:Destroy()
            end
            pcall(function()
                tab.Page.CanvasPosition = Vector2.new(0, 0)
            end)
        end)

        twOut:Play()
        twIn:Play()
    end

    -- Resolve JumpTo target: Tab, searchable entry, flag string, or control name.
    local function resolveTarget(target)
        if not target then return nil end
        if type(target) == "table" then
            if target.Page and target.Button then return { _isTab = true, Tab = target } end
            if target.Frame and target.Tab then return target end
        end
        if type(target) == "string" then
            local entry = Window.SearchByFlag[target]
            if entry then return entry end
            local low = string.lower(target)
            for _, e in ipairs(Window.Searchables) do
                if e.LowerName == low then return e end
            end
            for _, e in ipairs(Window.Searchables) do
                if e.LowerName and string.find(e.LowerName, low, 1, true) then return e end
            end
            for _, t in ipairs(Window.Tabs) do
                if string.lower(t.Name or "") == low then
                    return { _isTab = true, Tab = t }
                end
            end
        end
        return nil
    end

    function Window:JumpTo(target)
        local entry = resolveTarget(target)
        if not entry then return end
        local tab = entry.Tab
        if not tab then return end

        local needSwipe = Window.ActiveTab ~= tab
        Window:SelectTab(tab)
        if entry._isTab then return end

        local delayT = needSwipe and 0.36 or 0
        task.delay(delayT, function()
            local pg = tab.Page
            local fr = entry.Frame
            if not pg or not fr or not fr.Parent then return end

            local relY = fr.AbsolutePosition.Y - pg.AbsolutePosition.Y + pg.CanvasPosition.Y
            local goal = math.max(0, relY - 12)
            TweenService:Create(
                pg,
                TweenInfo.new(0.32, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
                { CanvasPosition = Vector2.new(0, goal) }
            ):Play()

            local highlight = new("Frame", {
                Size = UDim2.fromScale(1, 1),
                BackgroundColor3 = theme.AccentHi,
                BackgroundTransparency = 0.55,
                BorderSizePixel = 0,
                ZIndex = 99,
                Parent = fr,
            })
            corner(highlight, 10)
            local hStroke = new("UIStroke", {
                Color = theme.AccentHi,
                Thickness = 2,
                Transparency = 0.05,
                ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
                Parent = highlight,
            })
            tween(highlight, 1.0, { BackgroundTransparency = 1 })
            tween(hStroke, 1.0, { Transparency = 1 })
            task.delay(1.05, function()
                if highlight and highlight.Parent then highlight:Destroy() end
            end)
        end)
    end

