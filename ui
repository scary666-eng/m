local function cloneConfigValue(v)
    local tv = typeof(v)
    if tv == "Color3" then
        return Color3.new(v.R, v.G, v.B)
    end
    if type(v) == "table" then
        local out = {}
        for k, vv in pairs(v) do
            out[k] = cloneConfigValue(vv)
        end
        return out
    end
    return v
