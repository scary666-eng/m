        ResetOnSpawn = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        DisplayOrder = 9990,
        Parent = host,
    })
    installVantaFontWarmup(gui)

    -- Plain Frame stack (sharp). Fade uses stepped emulated transparency — not CanvasGroup (blur).
    local canvas = new("Frame", {
        Size = UDim2.fromScale(1, 1),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Parent = gui,
    })

    local fadeRoot = new("Frame", {
        Name = "VantaFadeRoot",
        Size = UDim2.fromScale(1, 1),
        Position = UDim2.fromScale(0, 0),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Parent = canvas,
    })

    local fadeRunToken = 0
    local currentEmulatedGroupT = 0
    local toggleFadeBaseline
    local FADE_STEPS = 12
    local FADE_STEP_SEC = 0.02

    local function stopCanvasFadeTween()
        fadeRunToken = fadeRunToken + 1
    end

    local function runSteppedFade(toG, onComplete)
        fadeRunToken = fadeRunToken + 1
        local myTok = fadeRunToken
        if not toggleFadeBaseline then
            toggleFadeBaseline = collectTransparencyBaseline(fadeRoot)
        end
        local b = toggleFadeBaseline
        local fromG = currentEmulatedGroupT
        if fromG == toG then
            if onComplete then onComplete() end
            return
        end
        task.spawn(function()
            for step = 1, FADE_STEPS do
                if myTok ~= fadeRunToken then return end
                local u = step / FADE_STEPS
                u = 1 - math.pow(1 - u, 3)
                local g = fromG + (toG - fromG) * u
                applyEmulatedGroupTransparency(b, g)
                currentEmulatedGroupT = g
                task.wait(FADE_STEP_SEC)
            end
            if myTok ~= fadeRunToken then return end
            applyEmulatedGroupTransparency(b, toG)
            currentEmulatedGroupT = toG
            if onComplete then onComplete() end
        end)
    end

    -- container holds shadow + glow + card so they track together
    local windowFrame = new("Frame", {
        AnchorPoint = Vector2.new(0.5, 0.5),
