        end

        local function canOpenSearchFromHotkey()
            return canvas and canvas.Parent and canvas.Visible and not Window.HiddenByToggle
        end

        UserInputService.InputBegan:Connect(function(inp, gp)
            if inp.UserInputType ~= Enum.UserInputType.Keyboard then return end
            local kc = inp.KeyCode
            if not searchVisible then
                if not gp and kc == Enum.KeyCode.Semicolon and canOpenSearchFromHotkey() then
                    openSearch()
                end
                return
            end
            if kc == Enum.KeyCode.Escape then
                closeSearch()
            elseif kc == Enum.KeyCode.Return then
                activateIdx()
            elseif kc == Enum.KeyCode.Down then
                if #activeMatches > 0 then
                    activeIdx = (activeIdx % #activeMatches) + 1
                    highlightActive()
                end
            elseif kc == Enum.KeyCode.Up then
                if #activeMatches > 0 then
                    activeIdx = ((activeIdx - 2) % #activeMatches) + 1
                    highlightActive()
                end
            end
        end)
    end

    -- Auto-add Settings tab after user tabs (task.defer fires when caller yields/finishes,
    -- so it lands at the end of the sidebar). Pass cfg.SettingsTab = false to opt out.
    if cfg.SettingsTab ~= false then
        task.defer(function()
            if Window and not Window._settingsTabCreated then
                Window._settingsTabCreated = true
                pcall(function()
                    Window:CreateSettingsTab(cfg.SettingsTabOptions)
                end)
            end
        end)
    end

    if cfgSave and (cfgSave.LoadOnStart or cfgSave.AutoLoad) then
        task.defer(function()
            pcall(function()
                Window:LoadConfig(cfgSave.FileName or Window.ConfigFile)
            end)
        end)
    end

    Library.Windows[name] = Window
    return Window
end

local notifStack = {}
function Library:Notify(opts)
    opts = opts or {}
    local host = hostGui()
    local notifGui = host:FindFirstChild("VantaNotifs")
    if not notifGui then
        notifGui = new("ScreenGui", {
            Name = "VantaNotifs",
            IgnoreGuiInset = true,
            ResetOnSpawn = false,
            ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
            DisplayOrder = 10000,
            Parent = host,
        })
    end

    local theme = THEME
    local holder = new("Frame", {
        AnchorPoint = Vector2.new(1, 0),
        Position = UDim2.new(1, -20, 0, 20 + (#notifStack * 96)),
        Size = UDim2.fromOffset(320, 84),
        BackgroundTransparency = 1,
        Parent = notifGui,
    })

    -- Rounded masks keep the blur/glow from rendering square at the bottom corners.
    local shadowMask = new("Frame", {
        Position = UDim2.fromOffset(-22, -22),
        Size = UDim2.new(1, 44, 1, 44),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ClipsDescendants = true,
        Parent = holder,
    })
    corner(shadowMask, 24)
    local notifShadow = new("ImageLabel", {
        Size = UDim2.fromScale(1, 1),
        BackgroundTransparency = 1,
        Image = SHADOW_ASSET,
        ImageColor3 = Color3.new(0, 0, 0),
        ImageTransparency = 1,
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = SHADOW_SLICE,
        Parent = shadowMask,
    })

    local glowMask = new("Frame", {
        Position = UDim2.fromOffset(-14, -14),
        Size = UDim2.new(1, 28, 1, 28),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ClipsDescendants = true,
        Parent = holder,
    })
    corner(glowMask, 20)
    local notifGlow = new("ImageLabel", {
        Size = UDim2.fromScale(1, 1),
        BackgroundTransparency = 1,
        Image = SHADOW_ASSET,
        ImageColor3 = theme.Accent,
        ImageTransparency = 1,
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = SHADOW_SLICE,
        Parent = glowMask,
    })

    local card = new("Frame", {
        Size = UDim2.fromScale(1, 1),
        BackgroundColor3 = theme.Card,
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ClipsDescendants = true,
        Parent = holder,
    })
    corner(card, 14)
    local cs = stroke(card, theme.Accent, 1, 1)

    local bar = new("Frame", {
        Size = UDim2.fromOffset(3, 0),
        Position = UDim2.fromOffset(8, 10),
        BackgroundColor3 = theme.Accent,
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Parent = card,
    })
    corner(bar, 999)

    local ttl = new("TextLabel", {
        BackgroundTransparency = 1,
        Position = UDim2.fromOffset(16, 12),
        Size = UDim2.new(1, -32, 0, 18),
        Font = Enum.Font.GothamBold,
        TextSize = 13,
        TextColor3 = theme.Text,
        TextTransparency = 1,
        TextXAlignment = Enum.TextXAlignment.Left,
        Text = opts.Title or "Notification",
        Parent = card,
    })
    local body = new("TextLabel", {
        BackgroundTransparency = 1,
        Position = UDim2.fromOffset(16, 34),
        Size = UDim2.new(1, -32, 0, 38),
        Font = Enum.Font.Gotham,
        TextSize = 12,
        TextColor3 = theme.SubText,
        TextTransparency = 1,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Top,
        TextWrapped = true,
        Text = opts.Content or "",
        Parent = card,
    })

    table.insert(notifStack, holder)

    tween(card, 0.25, {BackgroundTransparency = 0})
    tween(cs,   0.25, {Transparency = 0.4})
    tween(notifShadow, 0.3, {ImageTransparency = 0.4})
    tween(notifGlow,   0.3, {ImageTransparency = 0.65})
    tween(bar,  0.25, {Size = UDim2.new(0, 2, 1, -20), BackgroundTransparency = 0})
    tween(ttl,  0.25, {TextTransparency = 0})
    tween(body, 0.3,  {TextTransparency = 0})

    task.delay(opts.Duration or 4, function()
        tween(card, 0.25, {BackgroundTransparency = 1})
        tween(cs,   0.25, {Transparency = 1})
        tween(notifShadow, 0.25, {ImageTransparency = 1})
        tween(notifGlow,   0.25, {ImageTransparency = 1})
        tween(bar,  0.25, {BackgroundTransparency = 1})
        tween(ttl,  0.25, {TextTransparency = 1})
        local t = tween(body, 0.25, {TextTransparency = 1})
        t.Completed:Connect(function()
            for i, c in ipairs(notifStack) do
                if c == holder then table.remove(notifStack, i) break end
            end
            holder:Destroy()
            for i, c in ipairs(notifStack) do
                tween(c, 0.2, {Position = UDim2.new(1, -20, 0, 20 + ((i-1) * 96))})
            end
        end)
    end)
end

return Library
