local function encodeConfigValue(v)
    local tv = typeof(v)
    if tv == "Color3" then
        return {
            __vantaType = "Color3",
            r = v.R,
            g = v.G,
            b = v.B,
        }
    end
    if type(v) == "table" then
        local out = {}
        for k, vv in pairs(v) do
            if type(k) == "string" or type(k) == "number" then
                out[k] = encodeConfigValue(vv)
            end
        end
        return out
    end
    return v
end

local function decodeConfigValue(v)
    if type(v) ~= "table" then
        return v
    end
    if v.__vantaType == "Color3" then
        return Color3.new(tonumber(v.r) or 1, tonumber(v.g) or 1, tonumber(v.b) or 1)
    end
    local out = {}
    for k, vv in pairs(v) do
        if k ~= "__vantaType" then
            out[k] = decodeConfigValue(vv)
        end
    end
    return out
end

function Library:CreateWindow(cfg)
